# Puerto del servidor (en Render se asigna automaticamente)
PORT=5000

# Cadena de conexion de MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:contrasena@cluster0.xxxxx.mongodb.net/la-spirit?retryWrites=true&w=majority

# URL del frontend autorizada para CORS (en produccion, la URL de Vercel)
FRONTEND_URL=http://localhost:5173
